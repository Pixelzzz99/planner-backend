// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goals      Goal[]
  yearPlans  YearPlan[]
  categories Category[]
  habits     Habit[]
  recurringTasks RecurringTask[]
}

model Goal {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @db.Uuid
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  status    GoalStatus @default(TODO)
  year      Int        @default(dbgenerated("EXTRACT(YEAR FROM CURRENT_DATE)::int"))
  createdAt DateTime   @default(now())
}

enum GoalStatus {
  TODO
  IN_PROGRESS
  COMPLETED
}

model YearPlan {
  id     String      @id @default(uuid()) @db.Uuid
  userId String      @db.Uuid
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  year   Int
  months MonthPlan[]
}

model MonthPlan {
  id         String     @id @default(uuid()) @db.Uuid
  yearPlanId String     @db.Uuid
  yearPlan   YearPlan   @relation(fields: [yearPlanId], references: [id], onDelete: Cascade)
  month      Int
  weekPlans  WeekPlan[]
}

model WeekPlan {
  id          String    @id @default(uuid()) @db.Uuid
  monthPlanId String    @db.Uuid
  monthPlan   MonthPlan @relation(fields: [monthPlanId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime
  tasks       Task[]
  focus       Focus[]
}

model Focus {
  id          String      @id @default(uuid()) @db.Uuid
  weekPlanId  String      @db.Uuid
  weekPlan    WeekPlan    @relation(fields: [weekPlanId], references: [id], onDelete: Cascade)
  title       String
  description String
  status      FocusStatus @default(IN_PROGRESS)
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  plannedTime Int      @default(0)
  actualTime  Int      @default(0)
  tasks       Task[]
  createdAt   DateTime @default(now())

  recurringTasks RecurringTask[]

  @@unique([userId, name])
}

model Task {
  id            String     @id @default(uuid()) @db.Uuid
  weekPlanId    String     @db.Uuid
  weekPlan      WeekPlan   @relation(fields: [weekPlanId], references: [id], onDelete: Cascade)
  position      Float      @default(1.0)
  title         String
  description   String?
  priority      Priority
  duration      Int
  day           Int
  date          DateTime
  categoryId    String?    @db.Uuid
  category      Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  status        TaskStatus @default(TODO)
  isArchived    Boolean    @default(false)
  archiveReason String?
  archivedAt    DateTime?
  createdAt     DateTime   @default(now())
  recurringTaskId String?    @db.Uuid
  recurringTask   RecurringTask? @relation(fields: [recurringTaskId], references: [id], onDelete: SetNull)

  @@index([position])
  @@index([day])
  @@index([weekPlanId, isArchived])
  @@index([isArchived, day])
  @@index([weekPlanId, recurringTaskId])
}

model RecurringTask {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @db.Uuid
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  priority    Priority   @default(MEDIUM)
  duration    Int        @default(0)
  day         Int
  categoryId  String?    @db.Uuid
  category    Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  instances   Task[]

  @@index([userId, active])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
}

enum FocusStatus {
  IN_PROGRESS
  COMPLETED
  CANCELED
}

model Habit {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @db.Uuid
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  color     String?
  createdAt DateTime   @default(now())
  logs      HabitLog[]

  @@index([userId])
}

model HabitLog {
  id        String   @id @default(uuid()) @db.Uuid
  habitId   String   @db.Uuid
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  completed Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([habitId, date])
}
