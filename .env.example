# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/planner"

# Required — used to sign JWT access tokens (generate: openssl rand -base64 32)
JWT_SECRET="change-me-to-a-long-random-string"

# Production (Railway): set explicit origin OR rely on *.up.railway.app auto-allow on Railway
CORS_ORIGINS="https://planner-frontend-production.up.railway.app,*.up.railway.app"

# Optional — single frontend URL (also added to CORS allowlist)
FRONTEND_URL="https://planner-frontend-production.up.railway.app"

# Optional — default 3000
PORT=3000
